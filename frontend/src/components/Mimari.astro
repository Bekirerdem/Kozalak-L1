---
// Mimari — 3 katman (ICM → Teleporter → ICTT) ve deploy hedefi gösterimi.

const layers = [
    {
        name: "ICTT — Uygulama Katmanı",
        sub: "Token Home ↔ Token Remote — bizim contract'larımız",
        chip: "Token Home / Token Remote (ince wrapper)",
        bgClass: "bg-kozalak-red-deep",
        accentClass: "text-kozalak-red",
    },
    {
        name: "Teleporter — Mesaj Katmanı",
        sub: "Generic mesaj router + version registry",
        chip: "ava-labs audited (üzerine custom yazılmaz)",
        bgClass: "bg-kozalak-blue-deep",
        accentClass: "text-kozalak-blue",
    },
    {
        name: "ICM / Warp — Precompile Katmanı",
        sub: "Validator imzalı off-chain mesaj",
        chip: "0x0200...0005 — Subnet-EVM yerleşik",
        bgClass: "bg-bg-card-dark",
        accentClass: "text-white/60",
    },
];
---

<section id="mimari" class="relative w-full bg-bg-pure text-white py-24 lg:py-32 px-4 lg:px-8 overflow-hidden">
    <div class="max-w-[1400px] mx-auto">
        <!-- Section header -->
        <div class="flex items-center gap-4 mb-12 lg:mb-16">
            <span class="font-sans text-xs lg:text-sm font-bold tracking-[0.3em] uppercase text-kozalak-red">
                04 / Mimari
            </span>
            <span class="flex-1 h-px bg-white/10"></span>
        </div>

        <h2 class="font-sans font-bold leading-[0.95] tracking-tight text-4xl lg:text-[3.5rem] text-white max-w-3xl mb-12 lg:mb-16">
            Üç katman. <br/>
            <span class="text-white/40">Sadece üst katmana wrapper yazıyoruz.</span>
        </h2>

        <!-- Asymmetric: 7-col layers, 5-col deploy target -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
            <!-- LEFT: 3 layered cards -->
            <div class="lg:col-span-7 flex flex-col gap-3">
                {layers.map((layer, i) => (
                    <div
                        class={`${layer.bgClass} avax-chamfer-tr p-6 lg:p-8 border-t border-white/10 relative`}
                        style={`margin-left: ${i * 1.5}rem;`}
                    >
                        <div class="flex items-start justify-between gap-6 flex-wrap">
                            <div>
                                <div class={`font-sans text-xs font-bold tracking-widest uppercase mb-2 ${layer.accentClass}`}>
                                    Layer {i + 1}
                                </div>
                                <h3 class="font-sans font-bold leading-tight text-xl lg:text-2xl text-white mb-2">
                                    {layer.name}
                                </h3>
                                <p class="text-sm text-white/70 leading-relaxed max-w-md">
                                    {layer.sub}
                                </p>
                            </div>
                            <span class="text-[0.65rem] lg:text-xs font-mono tracking-tight bg-black/20 text-white/80 px-3 py-1.5 rounded-md whitespace-nowrap">
                                {layer.chip}
                            </span>
                        </div>
                    </div>
                ))}

                <p class="text-white/50 text-xs lg:text-sm leading-relaxed font-sans mt-6 italic">
                    Audit-grade prensibi: alt katmanlara dokunma. Sadece ICTT üzerine ince bir wrapper +
                    Türkçe NatSpec + production checklist katmanı eklenir.
                </p>
            </div>

            <!-- RIGHT: deploy hedefi -->
            <div class="lg:col-span-5 flex flex-col gap-4">
                <div class="bg-gradient-to-br from-kozalak-red to-kozalak-red-hot avax-chamfer-tr p-6 lg:p-8 relative overflow-hidden">
                    <div class="absolute -right-12 -top-12 opacity-20 pointer-events-none mix-blend-overlay">
                        <svg viewBox="0 0 200 200" class="w-56 h-56">
                            <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="2" fill="none" class="text-true-white"/>
                            <circle cx="100" cy="100" r="40" stroke="currentColor" stroke-width="2" fill="none" class="text-true-white"/>
                            <circle cx="100" cy="100" r="6" fill="currentColor" class="text-true-white"/>
                        </svg>
                    </div>
                    <div class="relative z-10">
                        <div class="text-true-white/80 font-sans text-xs font-bold tracking-widest uppercase mb-2">Deploy Hedefi</div>
                        <h3 class="text-true-white font-sans font-bold text-2xl lg:text-3xl leading-tight">Avalanche C-Chain</h3>
                        <p class="text-true-white/85 text-sm mt-2 leading-relaxed">Fuji 43113 / Mainnet 43114</p>
                    </div>
                </div>

                <div class="flex items-center justify-center text-white/40 font-mono text-xl py-1 select-none">
                    &darr; ICM / ICTT &darr;
                </div>

                <div class="bg-bg-card-dark avax-chamfer-tr p-6 lg:p-8 border border-white/5 relative">
                    <div class="text-kozalak-red font-sans text-xs font-bold tracking-widest uppercase mb-2">Custom Sovereign L1</div>
                    <h3 class="text-white font-sans font-bold text-2xl lg:text-3xl leading-tight">
                        Kendi chain ID, <br/>kendi gas token
                    </h3>
                    <div class="flex flex-wrap gap-2 mt-4">
                        <span class="text-[0.65rem] font-mono bg-white/5 text-white/70 px-2 py-1 rounded">Subnet-EVM</span>
                        <span class="text-[0.65rem] font-mono bg-white/5 text-white/70 px-2 py-1 rounded">PoA / PoS</span>
                        <span class="text-[0.65rem] font-mono bg-white/5 text-white/70 px-2 py-1 rounded">ICM açık</span>
                        <span class="text-[0.65rem] font-mono bg-white/5 text-white/70 px-2 py-1 rounded">99% ucuz</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
