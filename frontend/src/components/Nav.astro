---
const links = [
    {label: "Ne Bu?", href: "#ne-bu"},
    {label: "Şablonlar", href: "#sablonlar"},
    {label: "Kullan", href: "#kullan"},
    {label: "Mimari", href: "#mimari"},
    {label: "Yol Haritası", href: "#roadmap"},
    {label: "Dokümanlar", href: "https://github.com/Bekirerdem/Kozalak-L1/tree/main/docs/tr", external: true, isDoc: true},
];
---

<nav
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between bg-bg-primary border-b border-gray-700 h-[72px]"
>
    <!-- Left Logo Section -->
    <a href="/" class="flex items-center gap-2.5 group px-6 lg:px-8 border-r border-gray-700 h-full">
        <img
            src="/kozalak-logo.png"
            alt="Kozalak-L1 logo"
            class="h-8 w-8 rounded-md group-hover:scale-105 transition-transform"
            width="32"
            height="32"
        />
        <span class="font-sans text-base lg:text-lg font-bold tracking-tight text-white">
            Kozalak<span class="text-kozalak-red">-L1</span>
        </span>
    </a>

    <!-- Center Menu Section -->
    <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 items-center justify-center gap-8 text-sm h-full">
        {
            links.map((link) => (
                <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                    class="text-white/80 font-semibold hover:text-white transition-colors flex items-center gap-1"
                >
                    {link.label}
                    {link.isDoc && (
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/50">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    )}
                </a>
            ))
        }
    </div>

    <!-- Right Action Section -->
    <div class="flex items-center gap-4 px-6 lg:px-8 border-l border-gray-700 h-full">
        <!-- Interactive Theme toggle -->
        <button 
            id="theme-toggle" 
            class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-700 text-white/50 hover:text-white hover:border-white/50 transition-all cursor-pointer"
            aria-label="Toggle Dark/Light Mode"
        >
            <svg id="theme-icon-light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg id="theme-icon-dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        
        <a
            href="https://github.com/Bekirerdem/Kozalak-L1"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-6 py-2.5 bg-kozalak-red-hot text-true-white font-sans font-bold text-sm rounded-[12px] hover:bg-kozalak-red transition-colors"
        >
            GitHub'da İncele
            <svg
                width="14"
                height="14"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="transition-transform group-hover:translate-x-1"
            >
                <path
                    d="M3 8L13 8M13 8L9 4M13 8L9 12"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
        </a>
    </div>
</nav>

<script>
    // Theme toggle functionality
    const themeToggleBtn = document.getElementById('theme-toggle');
    const iconLight = document.getElementById('theme-icon-light');
    const iconDark = document.getElementById('theme-icon-dark');

    themeToggleBtn?.addEventListener('click', () => {
        // Toggle an active class for demo purposes
        // Note: For a full light mode, global.css variables need to be inverted for .light-theme
        document.documentElement.classList.toggle('light-theme');
        
        // Toggle icons
        if (document.documentElement.classList.contains('light-theme')) {
            iconDark?.classList.add('hidden');
            iconLight?.classList.remove('hidden');
        } else {
            iconLight?.classList.add('hidden');
            iconDark?.classList.remove('hidden');
        }
    });
</script>
