---
// Şablonlar — 5 template card'ı, her biri durum + Snowtrace link içerir.

interface Template {
    number: string;
    title: string;
    version: string;
    status: "live" | "planned";
    body: string;
    bgClass: string;
    textClass: string;
    snowtrace?: string;
    linkLabel?: string;
}

const templates: Template[] = [
    {
        number: "01",
        title: "ERC-20 + Custom Gas Token",
        version: "v0.1.0",
        status: "live",
        body: "Subnet-EVM için native gas token. Ownable2Step, Capped, ERC-2612 Permit.",
        bgClass: "bg-kozalak-red-deep",
        textClass: "text-true-white",
        snowtrace: "https://testnet.snowtrace.io/address/0x06451DD4Fb8ebFC19870DacC9568f4364D2A2eB0",
        linkLabel: "Fuji'de incele",
    },
    {
        number: "02",
        title: "ERC-721 NFT Collection",
        version: "v0.2.0",
        status: "live",
        body: "Merkle allowlist, ERC-2981 royalty, 3-faz mint (Closed / Allowlist / Public).",
        bgClass: "bg-kozalak-blue-deep",
        textClass: "text-true-white",
        snowtrace: "https://testnet.snowtrace.io/address/0x59347BB4365A18BBd92396Fd138E6cEfcDDb79C9",
        linkLabel: "Fuji'de incele",
    },
    {
        number: "03",
        title: "ICTT Cross-L1 Köprü",
        version: "v0.3.2",
        status: "live",
        body: "ava-labs/icm-contracts audited. Çift yön köprü doğrulandı: lock→mint ve burn→unlock (round-trip).",
        bgClass: "bg-kozalak-red-hot",
        textClass: "text-true-white",
        snowtrace: "https://testnet.snowtrace.io/address/0x2b1377537690793939DC42530c15DA897AC9D2D9",
        linkLabel: "Home @ Fuji",
    },
    {
        number: "04",
        title: "Soulbound Credential",
        version: "v0.4.0",
        status: "live",
        body: "Account-bound (transfer edilemez) eğitim/topluluk sertifikası. On-chain metadata, issuer-only mint, revoke-flag.",
        bgClass: "bg-kozalak-orange",
        textClass: "text-true-white",
        snowtrace: "https://testnet.snowtrace.io/address/0xCFdE91F214ABDe2a2E65B6cd41A7C7E3244E1ec1",
        linkLabel: "Fuji'de incele",
    },
    {
        number: "05",
        title: "Treasury Multisig + Timelock",
        version: "v0.5.0",
        status: "live",
        body: "OpenZeppelin TimelockController. Rol-bazlı + gecikmeli hazine (DAO fonları), Safe (Gnosis) uyumlu.",
        bgClass: "bg-bg-card-dark",
        textClass: "text-white",
        snowtrace: "https://testnet.snowtrace.io/address/0x6864879522D70Fb8e1583Cc8Fd4baB0e9605A955",
        linkLabel: "Fuji'de incele",
    },
];
---

<section id="sablonlar" class="relative w-full bg-bg-primary text-white py-24 lg:py-32 px-4 lg:px-8">
    <div class="max-w-[1400px] mx-auto">
        <!-- Section header -->
        <div class="flex items-center gap-4 mb-12 lg:mb-16">
            <span class="font-sans text-xs lg:text-sm font-bold tracking-[0.3em] uppercase text-kozalak-red">
                02 / Şablonlar
            </span>
            <span class="flex-1 h-px bg-white/10"></span>
            <span class="text-white/40 text-xs lg:text-sm font-medium">
                5 / 5 canlı
            </span>
        </div>

        <h2 class="font-sans font-bold leading-[0.95] tracking-tight text-4xl lg:text-[3.5rem] text-white max-w-3xl mb-12 lg:mb-16">
            Beş audit-grade şablon. <br/>
            <span class="text-white/40">Hepsi Türkçe rehberle.</span>
        </h2>

        <!-- Grid: 2 row x flex layout -->
        <div class="grid grid-cols-1 lg:grid-cols-6 gap-4 lg:gap-5">
            {templates.map((tpl, idx) => (
                <article
                    class={`${tpl.bgClass} ${tpl.textClass} avax-chamfer-tr p-6 lg:p-8 flex flex-col justify-between min-h-[280px] lg:min-h-[320px] ${idx < 3 ? "lg:col-span-2" : "lg:col-span-3"}`}
                >
                    <div class="flex items-start justify-between gap-4 mb-6">
                        <span class="font-sans text-xs font-bold tracking-widest uppercase opacity-60">
                            {tpl.number} / {tpl.version}
                        </span>
                        {tpl.status === "live" ? (
                            <span class="inline-flex items-center gap-1.5 text-[0.65rem] lg:text-xs font-bold tracking-widest uppercase bg-white/15 px-2 py-1 rounded-full">
                                <span class="relative flex h-1.5 w-1.5">
                                    <span class="absolute inline-flex h-full w-full rounded-full bg-white opacity-75 animate-ping" />
                                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white" />
                                </span>
                                CANLI
                            </span>
                        ) : (
                            <span class="text-[0.65rem] lg:text-xs font-bold tracking-widest uppercase opacity-50">
                                PLAN
                            </span>
                        )}
                    </div>

                    <div class="flex-1">
                        <h3 class="font-sans font-bold leading-tight tracking-tight text-2xl lg:text-3xl mb-3">
                            {tpl.title}
                        </h3>
                        <p class="text-sm lg:text-base opacity-85 leading-relaxed">
                            {tpl.body}
                        </p>
                    </div>

                    {tpl.snowtrace && (
                        <a
                            href={tpl.snowtrace}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 mt-6 text-xs lg:text-sm font-bold tracking-wide uppercase opacity-90 hover:opacity-100 group/link"
                        >
                            {tpl.linkLabel}
                            <svg class="w-3.5 h-3.5 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                            </svg>
                        </a>
                    )}
                </article>
            ))}
        </div>
    </div>
</section>
