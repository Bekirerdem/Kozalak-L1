---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import NeBu from "@/components/NeBu.astro";
import Sablonlar from "@/components/Sablonlar.astro";
import Kullan from "@/components/Kullan.astro";
import Mimari from "@/components/Mimari.astro";
import StackingCards from "@/components/StackingCards.astro";
import YolHaritasi from "@/components/YolHaritasi.astro";
---

<Layout>
    <Nav />
    <main class="bg-bg-primary text-white">
        <Hero />

        <!-- 01 / Ne Bu? -->
        <NeBu />

        <!-- 02 / Şablonlar -->
        <Sablonlar />

        <!-- 03 / Kullan -->
        <Kullan />

        <!-- 04 / Mimari -->
        <Mimari />

        <!-- MEGA TITLE & STACKING CARDS WRAPPER -->
        <div class="relative w-full">
            <!-- MEGA TITLE — Pinned background -->
            <div class="sticky top-0 flex flex-col justify-center h-screen w-full overflow-hidden z-0 pointer-events-none">
                <h2
                    class="font-sans font-medium tracking-tighter uppercase leading-[0.85] text-[clamp(3.5rem,14vw,18rem)] whitespace-nowrap pl-4 lg:pl-12 opacity-30 lg:opacity-70"
                >
                    <span class="split-line"><span>WHY</span></span>
                    <span class="split-line"><span>KOZALAK-L1</span></span>
                </h2>
            </div>

            <!-- AVAX-STYLE STACKING CARDS — pinned, multi-color, on-scroll -->
            <div class="relative z-10 pb-32 mt-[100vh] pt-[20vh] lg:pt-[40vh]">
                <StackingCards />
            </div>
        </div>

        <!-- 05 / Yol Haritası -->
        <YolHaritasi />

        <footer class="relative w-full px-8 py-16 border-t border-gray-700 bg-bg-primary">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 max-w-7xl mx-auto">
                <a href="/" class="flex items-center gap-2.5 group">
                    <img
                        src="/kozalak-logo.png"
                        alt="Kozalak-L1 logo"
                        class="h-8 w-8 rounded-md group-hover:scale-105 transition-transform"
                        width="32"
                        height="32"
                    />
                    <span class="font-sans text-base lg:text-lg font-bold tracking-tight text-white">
                        Kozalak<span class="text-kozalak-red">-L1</span>
                    </span>
                </a>
                <div class="flex flex-wrap items-center gap-x-6 gap-y-4 text-sm font-semibold text-white/60">
                    <a
                        href="https://github.com/Bekirerdem/Kozalak-L1"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-white transition-colors"
                    >
                        GitHub
                    </a>
                    <span class="text-white/30">·</span>
                    <span class="text-white/50 font-medium tracking-wide uppercase text-xs">Canlı Şablonlar</span>
                    <a
                        href="https://testnet.snowtrace.io/address/0x06451DD4Fb8ebFC19870DacC9568f4364D2A2eB0"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-white transition-colors"
                        title="ERC-20 Custom Gas Token — Fuji testnet"
                    >
                        v0.1.0 KGAS
                    </a>
                    <a
                        href="https://testnet.snowtrace.io/address/0x59347BB4365A18BBd92396Fd138E6cEfcDDb79C9"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-white transition-colors"
                        title="ERC-721 NFT Collection — Fuji testnet"
                    >
                        v0.2.0 NFT
                    </a>
                    <a
                        href="https://testnet.snowtrace.io/address/0x2b1377537690793939DC42530c15DA897AC9D2D9"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-white transition-colors"
                        title="ICTT Cross-L1 Bridge Home — Fuji testnet"
                    >
                        v0.3.1 ICTT
                    </a>
                    <span class="text-white/30">·</span>
                    <a
                        href="https://team1.blog"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-white transition-colors"
                    >
                        Team1 TR
                    </a>
                    <span class="text-white/40 ml-4 font-normal">
                        © 2026 Bekir Erdem
                    </span>
                </div>
            </div>
        </footer>
    </main>
</Layout>
